{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile LaTeX (Auto-detect)",
            "type": "shell",
            "command": "python",
            "args": ["${workspaceFolder}/scripts/auto_compile.py", "${file}"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Automatically compiles LaTeX project by detecting the folder of the current .tex file (cross-platform)"
        },
        {
            "label": "Build LaTeX Docker Image",
            "type": "shell",
            "command": "python",
            "args": ["${workspaceFolder}/scripts/build.py"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Builds the LaTeX Docker image (cross-platform)"
        },
        {
            "label": "Compile LaTeX Directory",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/scripts/compile.py",
                "${input:latexDirectory}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "detail": "Compiles LaTeX files in a specific directory (cross-platform)"
        }
    ],
    "inputs": [
        {
            "id": "latexDirectory",
            "description": "LaTeX directory to compile (relative to ws_latex/)",
            "default": "master-thesis",
            "type": "promptString"
        }
    ]
}
